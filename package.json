{
  "name": "BookMyShow_CICD",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db-prisma-migrate": "cd packages/db && npx prisma migrate dev",
    "db-prisma-generate": "cd packages/db && npx prisma generate",
    "start:http": "cd apps/http-server && npm run start",
    "start:ws": "cd apps/ws-server && npm run start",
    "start:web": "cd apps/web && npm run start"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.6.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
